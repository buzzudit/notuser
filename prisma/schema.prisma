generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Message {
  id        Int      @id @default(autoincrement())
  message   String
  createdAt DateTime @default(now())
}

model PortfolioShareLink {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  company   String
  position  String?
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
}

model IntentLink {
  id            Int      @id @default(autoincrement())
  code          String   @unique
  org           String
  positionTitle String?
  positionUrl   String?
  intentType    String?
  notes         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([createdAt])
}
